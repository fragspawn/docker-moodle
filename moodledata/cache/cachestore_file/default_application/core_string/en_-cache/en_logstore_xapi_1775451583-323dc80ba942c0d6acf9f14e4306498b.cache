a:105:{s:16:"account_homepage";s:22:"Actor Account HomePage";s:21:"account_homepage_desc";s:67:"Set the homePage field for actor accounts. Defaults to the app_url.";s:9:"autherror";s:157:"The server is returning a 401 error. Please ensure the endpoint, username and auth secret/password for
    the xAPI is correct in the Logstore xAPI settings.";s:14:"backgroundmode";s:34:"Send statements by scheduled task?";s:19:"backgroundmode_desc";s:289:"This will force Moodle to send the statements to the LRS in the background,
        via a cron task to avoid blocking page responses. This will make the process less close to real time, but will help to prevent unpredictable
        Moodle performance linked to the performance of the LRS.";s:7:"cohorts";s:7:"Cohorts";s:12:"cohorts_help";s:30:"Add cohort(s) to notifications";s:19:"confirmresendevents";s:102:"You are about to send {$a->count} record(s) to the queue for reprocessing.<br>Do you wish to continue?";s:25:"confirmresendeventsheader";s:13:"Resend events";s:17:"confirmsendevents";s:102:"You are about to send {$a->count} record(s) to the queue for reprocessing.<br>Do you wish to continue?";s:23:"confirmsendeventsheader";s:11:"Send events";s:16:"context_platform";s:16:"Context Platform";s:21:"context_platform_desc";s:72:"Set the context platform field of xAPI statements. Defaults to "Moodle".";s:23:"contextidnolongerexists";s:32:"Context ID {$a} no longer exists";s:5:"count";s:5:"Count";s:11:"datetimegmt";s:15:"Date/Time (GMT)";s:16:"datetovalidation";s:42:"The To date cannot be before the From date";s:26:"enablesendingnotifications";s:19:"Send notifications?";s:31:"enablesendingnotifications_desc";s:65:"Control if notifications should be sent to configured recipients.";s:8:"endpoint";s:30:"Your LRS endpoint for the xAPI";s:12:"errorlogpage";s:14:"Error log page";s:24:"errornotificationtrigger";s:26:"Error notification trigger";s:29:"errornotificationtrigger_desc";s:158:"Threshold value at which point notifications will be triggered. When a number of errors greater than this value have been generated, the notification is sent.";s:9:"errortype";s:10:"Error Type";s:12:"eventcontext";s:13:"Event Context";s:9:"eventname";s:10:"Event Name";s:6:"failed";s:6:"Failed";s:13:"failed_events";s:40:"event(s) have failed to send to the LRS.";s:13:"failedsubject";s:45:"XAPI Logstore: failed to send messages report";s:12:"failedtosend";s:59:"The following statements have failed to be sent to the LDH.";s:23:"failedtransformresponse";s:46:"Event: "{$a}" was not transformed successfully";s:10:"failurelog";s:11:"Failure log";s:7:"filters";s:11:"Filter logs";s:12:"filters_help";s:54:"Enable filters that INCLUDE some actions to be logged.";s:14:"includecohorts";s:38:"Include these cohorts in notifications";s:4:"info";s:4:"Info";s:29:"insendfailednotificationstask";s:41:"In send failed notifications task execute";s:11:"lmsinstance";s:43:"LMS instance on which the error(s) occurred";s:9:"logguests";s:17:"Log guest actions";s:20:"logstorexapierrorlog";s:23:"Logstore xAPI Error Log";s:23:"logstorexapihistoriclog";s:26:"Logstore xAPI Historic Log";s:8:"lrserror";s:72:"There is a problem with the LDH. The LDH has responded with a 500 error.";s:12:"maxbatchsize";s:18:"Maximum batch size";s:17:"maxbatchsize_desc";s:265:"Statements are sent to the LRS in batches. This setting controls the maximum number of
        statements that will be sent in a single operation. Setting this to zero will cause all available statements to
        be sent at once, although this is not recommended.";s:21:"maxbatchsizeforfailed";s:38:"Maximum batch size for failed requests";s:26:"maxbatchsizeforfailed_desc";s:285:"Statements are sent to the LRS in batches. This setting controls the maximum number of
        statements that will be sent in a single operation for failed requests. Setting this to zero will cause all available statements to
        be sent at once, although this is not recommended.";s:25:"maxbatchsizeforhistorical";s:42:"Maximum batch size for historical requests";s:30:"maxbatchsizeforhistorical_desc";s:289:"Statements are sent to the LRS in batches. This setting controls the maximum number of
        statements that will be sent in a single operation for historical requests. Setting this to zero will cause all available statements to
        be sent at once, although this is not recommended.";s:4:"mbox";s:23:"Identify users by email";s:9:"mbox_desc";s:79:"Statements will identify users with their email (mbox) when this box is ticked.";s:12:"networkerror";s:47:"There was a network error sending the response.";s:13:"noerrorsfound";s:15:"No errors found";s:6:"norows";s:17:"No rows to report";s:23:"notificationsnotenabled";s:25:"Notifications not enabled";s:34:"notificationtriggerlimitnotreached";s:38:"Notification trigger limit not reached";s:8:"password";s:48:"Your LRS basic auth secret/password for the xAPI";s:20:"pluginadministration";s:28:"Logstore xAPI administration";s:10:"pluginname";s:13:"Logstore xAPI";s:41:"privacy:metadata:logstore_xapi_failed_log";s:36:"xAPI holding table for failed events";s:48:"privacy:metadata:logstore_xapi_failed_log:userid";s:47:"User Id of xAPI holding table for failed events";s:34:"privacy:metadata:logstore_xapi_log";s:38:"xAPI holding table for cron processing";s:41:"privacy:metadata:logstore_xapi_log:userid";s:49:"User Id of xAPI holding table for cron processing";s:11:"recipeerror";s:80:"The LDH responded with a 400 error, this can be due to an issue with the recipe.";s:11:"replayevent";s:12:"Replay event";s:12:"resendevents";s:20:"Resend ({$a->count})";s:19:"resendevents:failed";s:42:"Events failed to be sent for reprocessing.";s:20:"resendevents:success";s:42:"Events successfully sent for reprocessing.";s:19:"resendfailedbatches";s:21:"Resend failed batches";s:24:"resendfailedbatches_desc";s:175:"When processing events in batches, try re-sending events in smaller batches if a batch fails. If not selected, the whole batch will not be sent in the event of a failed event.";s:8:"response";s:8:"Response";s:6:"routes";s:33:"Include actions with these routes";s:31:"send_additional_email_addresses";s:26:"Additional email addresses";s:36:"send_additional_email_addresses_desc";s:70:"Send notifications to list of email addresses. Comma separated values.";s:14:"send_jis